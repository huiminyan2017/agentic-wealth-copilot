# =============================================================================
# Agentic Wealth Copilot - Environment Configuration
# =============================================================================
# All settings have sensible defaults - only set what you need to override.

# =============================================================================
# Application Environment
# =============================================================================
APP_ENV=dev                    # dev, staging, prod
DEBUG=false                    # Enable debug mode with verbose logging
LOG_LEVEL=INFO                 # DEBUG, INFO, WARNING, ERROR

# =============================================================================
# Backend Server Configuration
# =============================================================================
BACKEND_HOST=127.0.0.1         # Host to bind the FastAPI server
BACKEND_PORT=8000              # Port for the FastAPI server
API_PREFIX=/api                # API route prefix

# =============================================================================
# Frontend Configuration
# =============================================================================
FRONTEND_PORT=8501             # Port for the Streamlit frontend (also used for CORS)

# =============================================================================
# Data Storage Paths
# =============================================================================
DATA_DIR=data                  # Base directory for all data storage
RAW_DATA_DIR=data/raw          # Directory for raw uploaded files
PARSED_DATA_DIR=data/parsed    # Directory for parsed JSON data
LOGS_DIR=data/logs             # Directory for application logs

# =============================================================================
# OpenAI / LLM Configuration
# =============================================================================
OPENAI_API_KEY=                # Your OpenAI API key (required for AI features)
OPENAI_MODEL=gpt-4o-mini       # Model for chat/vision tasks
OPENAI_EMBEDDING_MODEL=text-embedding-3-small  # Model for embeddings
OPENAI_MAX_TOKENS=2000         # Max tokens for LLM responses
OPENAI_TEMPERATURE=0.1         # Temperature (0-1, lower = more deterministic)

# =============================================================================
# Azure Document Intelligence (optional, for advanced document parsing)
# =============================================================================
AZURE_DOC_INTELLIGENCE_ENDPOINT=   # Azure endpoint URL
AZURE_DOC_INTELLIGENCE_KEY=        # Azure API key

# =============================================================================
# SMTP Email (for stock price alerts)
# =============================================================================
# Gmail example: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, use an App Password
SMTP_HOST=                     # e.g. smtp.gmail.com
SMTP_PORT=587                  # 587 for STARTTLS, 465 for SSL
SMTP_USER=                     # Login username (usually your email address)
SMTP_PASSWORD=                 # Login password or App Password
SMTP_FROM=                     # Sender address (defaults to SMTP_USER if blank)
SMTP_USE_TLS=true              # true = STARTTLS (recommended)

# =============================================================================
# Rate Limiting / Performance
# =============================================================================
MAX_UPLOAD_SIZE_MB=10          # Maximum file upload size in MB
API_RATE_LIMIT=100             # API requests per minute limit
